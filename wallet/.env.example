# Server API credential and environment — https://app.dynamic.xyz/dashboard/developer/api
DYNAMIC_AUTH_TOKEN=
DYNAMIC_ENVIRONMENT_ID=
WALLET_PASSWORD=

# Base Sepolia HTTP RPC (ERC-7702 set-code tx + MetaMask smart account)
RPC_URL=

# Game master wallet JSON (idempotent create). Default: .game-master-wallet.json in the wallet package directory
# GAME_MASTER_WALLET_FILE=

# Player wallets JSON (get-player-wallets, transfer-funds). Default: .player-wallets.json in the wallet package directory
# PLAYER_WALLETS_FILE=
