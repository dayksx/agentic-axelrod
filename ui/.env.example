NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only: used by /api/join-tournament and /api/register-player for DB writes
SUPABASE_SECRET_KEY=

# Wallet HTTP service (wallet package). Proxied by POST /api/wallet/agents
WALLET_SERVICE_URL=http://127.0.0.1:3210

# Used for balance reads; the app targets Ethereum Sepolia (11155111) end-to-end.
NEXT_PUBLIC_SEPOLIA_RPC_URL=

# Dynamic — enable Sepolia under Chains & Networks in the dashboard
# https://app.dynamic.xyz/dashboard/developer/api
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=