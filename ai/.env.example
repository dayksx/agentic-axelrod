# ═══════════════════════════════════════════════════════════════════════════════
#  Trustless Agent Workshop — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ── LLM (OpenAI-compatible API) ────────────────────────────────────────────────
# Any provider with an OpenAI-style /v1/chat/completions endpoint works.
# Auth: use LLM_API_KEY, or fall back to OPENAI_API_KEY.
LLM_API_KEY=

# Preset: openai (default) | deepseek | groq — picks default base URL + model.
# LLM_PROFILE=deepseek

# Optional overrides:
# LLM_BASE_URL=https://api.example.com/v1
# LLM_MODEL=my-model-id

# ── LangSmith ───────────────────────────────────────────────────────────────────
# Tracing for agent runtime and tools
# Get API key from https://smith.langchain.com/
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="eth-global-cannes-2026"
