# ═══════════════════════════════════════════════════════════════════════════════
#  Trustless Agent Workshop — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ── LLM & Agent ───────────────────────────────────────────────────────────────
# API key for your LLM provider (OpenAI, Anthropic, etc.) — used by the agent runtime
# Get API key from https://console.mistral.ai/ or https://console.anthropic.com/ or https://platform.openai.com/
LLM_API_KEY=
# Optional: if unset, OPENAI_API_KEY is used (OpenAI-compatible SDK default).

# ── LangSmith ───────────────────────────────────────────────────────────────────
# Tracing for agent runtime and tools
# Get API key from https://smith.langchain.com/
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="eth-global-cannes-2026"

