# Copy to `.env` — loaded by `pnpm tournament`.
# Used for roster slots that omit `url` in the JSON (per-player `url` overrides each slot).
AGENT_SLOT_1_URL=http://127.0.0.1:3100
AGENT_SLOT_2_URL=http://127.0.0.1:3101
AGENT_SLOT_3_URL=http://127.0.0.1:3102
AGENT_SLOT_4_URL=http://127.0.0.1:3103
AGENT_SLOT_5_URL=http://127.0.0.1:3104
AGENT_SLOT_6_URL=http://127.0.0.1:3105

SUPABASE_URL=
SUPABASE_SECRET_KEY=

# On-chain stakes (optional). When true, GM collects stakes before play and pays top 3 after.
# Player addresses for Supabase agents: HTTP only — wallet service `POST /agents` (same as UI).
# WALLET_SERVICE_URL=http://127.0.0.1:3210
# Collect / distribute still use the in-process wallet SDK on the Game Master; set Dynamic + RPC:
# GM_COLLECT_STAKES=false
# DYNAMIC_AUTH_TOKEN=
# DYNAMIC_ENVIRONMENT_ID=
# WALLET_PASSWORD=
# RPC_URL=
# Wallet state (GM + per-name player wallets) defaults to `.game-master-wallet.json` and
# `.player-wallets.json` in the process cwd — same as `wallet` CLI. No extra env needed.

# Game Master HTTP API (`pnpm --filter game gm-server`)
# GM_HTTP_PORT=3200
# GM_HTTP_HOST=0.0.0.0
